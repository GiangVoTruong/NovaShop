# Copy thành .env — FE gọi /api, Vite proxy sang BE (mặc định localhost:8080)
# VITE_API_BASE_URL=/api

# Đích proxy (chỉ dev). Mặc định: http://localhost:8080
# VITE_PROXY_TARGET=http://localhost:8080

# Không chạy BE local — proxy sang Render:
# VITE_PROXY_TARGET=https://novashop-e4ir.onrender.com

# Hoặc gọi thẳng BE (cần CORS trên Spring), không qua proxy:
# VITE_API_BASE_URL=http://localhost:8080/api

# Production build: .env.production
VITE_API_BASE_URL=https://novashop-e4ir.onrender.com/api

# Google OAuth Web Client ID (Google Cloud Console)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
