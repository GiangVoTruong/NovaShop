# Copy to .env và chỉnh theo môi trường
#
# Dev (pnpm dev) — proxy Vite → Render, tránh CORS:
# VITE_API_BASE_URL=/api
#
# Build production (.env.production) — gọi thẳng Render:
# VITE_API_BASE_URL=https://novashop-e4ir.onrender.com/api
#
# Swagger: https://novashop-e4ir.onrender.com/swagger-ui/index.html
VITE_API_BASE_URL=/api
